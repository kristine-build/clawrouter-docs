{
  "openapi": "3.0.3",
  "info": {
    "title": "Gemini Native Audio API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://YOUR_BASE_URL"
    }
  ],
  "paths": {
    "/v1beta/models/{model}:generateContent": {
      "post": {
        "operationId": "generateGeminiContent",
        "summary": "Gemini 音频生成",
        "description": "使用 Gemini 模型生成内容（含语音相关配置）。",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "模型名称，例如 gemini-2.5-flash-preview-tts"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateContentRequest"
              },
              "example": {
                "contents": [
                  {
                    "parts": [
                      {
                        "text": "请用中文播报今天的天气摘要"
                      }
                    ]
                  }
                ],
                "generationConfig": {
                  "responseModalities": [
                    "AUDIO"
                  ],
                  "speechConfig": {
                    "voiceConfig": {
                      "prebuiltVoiceConfig": {
                        "voiceName": "Kore"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "请求成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateContentResponse"
                },
                "example": {
                  "candidates": [
                    {
                      "content": {
                        "role": "model",
                        "parts": [
                          {
                            "inlineData": {
                              "mimeType": "audio/wav",
                              "data": "BASE64_AUDIO_DATA"
                            }
                          }
                        ]
                      },
                      "finishReason": "STOP"
                    }
                  ],
                  "usageMetadata": {
                    "promptTokenCount": 12,
                    "candidatesTokenCount": 58,
                    "totalTokenCount": 70
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "example": {
                  "error": {
                    "code": 400,
                    "message": "Invalid request"
                  }
                }
              }
            }
          },
          "401": {
            "description": "鉴权失败"
          },
          "429": {
            "description": "请求过于频繁"
          },
          "500": {
            "description": "服务端错误"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key"
      }
    },
    "schemas": {
      "GenerateContentRequest": {
        "type": "object",
        "required": [
          "contents"
        ],
        "properties": {
          "contents": {
            "type": "array",
            "description": "输入内容列表",
            "items": {
              "$ref": "#/components/schemas/Content"
            }
          },
          "generationConfig": {
            "$ref": "#/components/schemas/GenerationConfig"
          }
        }
      },
      "Content": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "角色标识"
          },
          "parts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Part"
            }
          }
        }
      },
      "Part": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "文本内容"
          },
          "inlineData": {
            "$ref": "#/components/schemas/InlineData"
          }
        }
      },
      "InlineData": {
        "type": "object",
        "properties": {
          "mimeType": {
            "type": "string"
          },
          "data": {
            "type": "string",
            "description": "Base64 数据"
          }
        }
      },
      "GenerationConfig": {
        "type": "object",
        "properties": {
          "responseModalities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "speechConfig": {
            "$ref": "#/components/schemas/SpeechConfig"
          }
        }
      },
      "SpeechConfig": {
        "type": "object",
        "properties": {
          "voiceConfig": {
            "$ref": "#/components/schemas/VoiceConfig"
          }
        }
      },
      "VoiceConfig": {
        "type": "object",
        "properties": {
          "prebuiltVoiceConfig": {
            "$ref": "#/components/schemas/PrebuiltVoiceConfig"
          }
        }
      },
      "PrebuiltVoiceConfig": {
        "type": "object",
        "properties": {
          "voiceName": {
            "type": "string",
            "description": "语音名称"
          }
        }
      },
      "GenerateContentResponse": {
        "type": "object",
        "properties": {
          "candidates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Candidate"
            }
          },
          "usageMetadata": {
            "$ref": "#/components/schemas/UsageMetadata"
          }
        }
      },
      "Candidate": {
        "type": "object",
        "properties": {
          "content": {
            "$ref": "#/components/schemas/Content"
          },
          "finishReason": {
            "type": "string"
          }
        }
      },
      "UsageMetadata": {
        "type": "object",
        "properties": {
          "promptTokenCount": {
            "type": "integer"
          },
          "candidatesTokenCount": {
            "type": "integer"
          },
          "totalTokenCount": {
            "type": "integer"
          }
        }
      }
    }
  }
}
